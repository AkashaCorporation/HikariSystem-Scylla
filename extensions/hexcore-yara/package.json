{
	"name": "hexcore-yara",
	"displayName": "HexCore YARA Scanner",
	"description": "YARA rule scanner with DefenderYara integration for malware detection and threat scoring",
	"version": "2.1.0",
	"publisher": "hikarisystem",
	"license": "MIT",
	"engines": {
		"vscode": "^1.70.0"
	},
	"categories": [
		"Other",
		"Testing"
	],
	"keywords": [
		"yara",
		"malware",
		"scanner",
		"detection",
		"signatures",
		"defender",
		"threat-intelligence",
		"reverse-engineering"
	],
	"activationEvents": [
		"onCommand:hexcore.yara.scan",
		"onCommand:hexcore.yara.quickScan",
		"onCommand:hexcore.yara.scanWorkspace",
		"onCommand:hexcore.yara.loadDefender",
		"onCommand:hexcore.yara.loadCategory",
		"onCommand:hexcore.yara.updateRules",
		"onCommand:hexcore.yara.createRule",
		"onCommand:hexcore.yara.threatReport",
		"onView:hexcore.yara.results",
		"onView:hexcore.yara.rules"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "hexcore.yara.scan",
				"title": "YARA: Scan File",
				"category": "HexCore YARA",
				"icon": "$(search)"
			},
			{
				"command": "hexcore.yara.quickScan",
				"title": "YARA: Quick Threat Scan",
				"category": "HexCore YARA",
				"icon": "$(zap)"
			},
			{
				"command": "hexcore.yara.scanWorkspace",
				"title": "YARA: Scan Workspace",
				"category": "HexCore YARA"
			},
			{
				"command": "hexcore.yara.loadDefender",
				"title": "YARA: Load DefenderYara Rules",
				"category": "HexCore YARA",
				"icon": "$(cloud-download)"
			},
			{
				"command": "hexcore.yara.loadCategory",
				"title": "YARA: Load Category",
				"category": "HexCore YARA",
				"icon": "$(folder-library)"
			},
			{
				"command": "hexcore.yara.updateRules",
				"title": "YARA: Reload Rules",
				"category": "HexCore YARA"
			},
			{
				"command": "hexcore.yara.createRule",
				"title": "YARA: Create Rule from Selection",
				"category": "HexCore YARA"
			},
			{
				"command": "hexcore.yara.threatReport",
				"title": "YARA: Show Threat Report",
				"category": "HexCore YARA",
				"icon": "$(graph)"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "hexcore.yara.scan",
					"group": "hexcore@3"
				},
				{
					"command": "hexcore.yara.quickScan",
					"group": "hexcore@4"
				}
			],
			"view/title": [
				{
					"command": "hexcore.yara.loadCategory",
					"when": "view == hexcore.yara.rules",
					"group": "navigation"
				},
				{
					"command": "hexcore.yara.threatReport",
					"when": "view == hexcore.yara.results",
					"group": "navigation"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "hexcore-yara",
					"title": "YARA Scanner",
					"icon": "$(shield)"
				}
			]
		},
		"views": {
			"hexcore-yara": [
				{
					"type": "tree",
					"id": "hexcore.yara.results",
					"name": "Scan Results"
				},
				{
					"type": "tree",
					"id": "hexcore.yara.rules",
					"name": "Rules"
				}
			]
		},
		"configuration": {
			"title": "HexCore YARA",
			"properties": {
				"hexcore.yara.rulesPath": {
					"type": "string",
					"default": "",
					"description": "Path to custom YARA rules directory"
				},
				"hexcore.yara.defenderYaraPath": {
					"type": "string",
					"default": "",
					"description": "Path to DefenderYara rules directory (e.g., C:\\DefenderYara-main)"
				},
				"hexcore.yara.autoUpdate": {
					"type": "boolean",
					"default": true,
					"description": "Auto-reload rules on startup"
				},
				"hexcore.yara.maxFileSize": {
					"type": "number",
					"default": 52428800,
					"description": "Maximum file size to scan in bytes (default: 50MB)"
				}
			}
		}
	},
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/node": "^18.0.0",
		"@types/vscode": "^1.70.0",
		"typescript": "^5.0.0"
	}
}
